# Ambiente — Backend Vants
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env com valores reais no repositório.

# Porta do servidor (padrão: 4000)
PORT=4000

# Privy App ID e Secret (obter em dashboard.privy.io)
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# Origens CORS permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/vants

# Stellar — Emissor mockado de USDC (Hi-Li simulado, Testnet only)
# WHY: O backend usa o secret para emitir o payment de USDC após a Trustline.
# Gerar uma conta nova na testnet: stellar keys generate issuer --network testnet
ISSUER_PUBLIC_KEY=G...your_issuer_public_key_here
ISSUER_SECRET_KEY=S...your_issuer_secret_key_here

# Etherfuse Sandbox
ETHERFUSE_API_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=sua_chave_gerada_aqui

# Defindex — Motor de Rendimentos (Vaults)
# Obter API key em: https://api.defindex.io
DEFINDEX_API_KEY=sk_sua_api_key_aqui
# Endereço do contrato Soroban do Vault de USDC (Testnet)
DEFINDEX_USDC_VAULT_ADDRESS=C...endereco_do_vault_aqui